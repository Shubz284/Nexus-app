PORT=3000
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>/<database>
SESSION_SECRET=replace_with_long_random_secret
ACCESS_KEY=replace_with_access_jwt_secret
REFRESH_KEY=replace_with_refresh_jwt_secret
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback
FRONTEND_URI=http://localhost:5173

# Optional (used if you want strict extension origin matching)
EXTENSION_ORIGIN=chrome-extension://<extension-id>

# Optional (legacy fallback used in one auth callback branch)
UI_URL=http://localhost:5173

# Optional (if enabling email sender flow)
SENDER_EMAIL_ADDRESS=
GOOGLE_REFRESH_TOKEN=
